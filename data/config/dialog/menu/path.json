{
	"type": "multi_action",
	"title": {
		"text": "Path",
		"color": "aqua"
	},
	"can_close_with_escape": true,
	"pause": true,
	"after_action": "close",
	"columns": 3,
	"actions": [
		{"label": {"text": "Start",      "color": "green"},  "action": {"type": "run_command", "command": "trigger tls_Path set 1"}},
		{"label": {"text": "Checkpoint", "color":  "gold"},  "action": {"type": "run_command", "command": "trigger tls_Path set 2"}},
		{"label": {"text": "Finish",     "color":   "red"},  "action": {"type": "run_command", "command": "trigger tls_Path set 3"}},
		
		{"label": { "text": 	      "Back to ", "extra": [{"text": "menu", "color": "gold", "italic": true}]}, "action": {"type": "show_dialog", "dialog":   "config:menu"}},
		{"label": { "text": "Back to main menu"}, 																 "action": {"type": "show_dialog", "dialog": "config:config"}}
	]
}
