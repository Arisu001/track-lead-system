{
	"type": "multi_action",
	"title": {
		"text": "Ghost",
		"color": "gray"
	},
	"inputs": [
		{
			"type": "single_option",
			"key": "toggle",
			"label": "Ghost",
			"options": [
				{"id": "disabled", "display":  {"text": "Disabled",  "color":  "gray"}, "initial": false},
				{"id": "activated", "display": {"text": "Activated", "color": "green"}, "initial": false}
			]
		}
	],
	"can_close_with_escape": true,
	"pause": true,
	"after_action": "close",
	"columns": 3,
	"actions": [
		{"label": "Confirm", "action": {"type": "dynamic/run_command", "template": "data modify storage config:settings toggle set value {ghost: \"$(toggle)\"}"}},
		
		{"label": { "text":           "Back to ", "extra": [{"text": "menu", "color": "gold", "italic": true}]}, "action": {"type": "show_dialog", "dialog":   "config:menu"}},
		{"label": { "text": "Back to main menu"}, 																 "action": {"type": "show_dialog", "dialog": "config:config"}}
	]
}
