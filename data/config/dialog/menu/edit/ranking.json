{
	"type": "multi_action",
	"title": {
		"text": "Ranking",
		"color": "gold"
	},
	"body": {
		"type": "item",
		"item": {
			"id": "nether_star"
		}
	},
	"inputs": [
		{
			"type": "single_option",
			"key": "rankings",
			"label": "Choose your rankings",
			"options": [
				{"id": "Top 3", "display": { "text": "Top 3", "color": "gold", "italic": true}, "initial": false},
				{"id": "Top 5", "display": { "text": "Top 5", "color": "blue", "italic": true}, "initial": false},
				{"id": "Top 10", "display": { "text": "Top 10", "color": "green", "italic": true}, "initial": false}
			]
		}
	],
	"can_close_with_escape": true,
	"pause": true,
	"after_action": "close",
	"columns": 2,
	"actions": [
		{"label": "Confirm", "action": {"type": "dynamic/run_command", "template": "data modify storage config:settings edit.ranking set value \"$(rankings)\""}},

		{"label": { "text": "Back to ", "extra": [{"text": "edit ", "color": "gold", "italic": true}, {"text": "menu"}]}, "action": {"type": "show_dialog", "dialog": "config:menu/edit"}},
		{"label": { "text": "Back to ", "extra": [{"text": "menu", "color": "gold", "italic": true}]}, "action": {"type": "show_dialog", "dialog": "config:menu"}},
		{"label": { "text": "Back to main menu"}, "action": {"type": "show_dialog", "dialog": "config:config"}}
	]
}
