{
	"type": "multi_action",
	"title": {
		"text": "Max Time",
		"color": "#EF4444"
	},
	"body": {
		"type": "item",
		"item": {
			"id": "clock"
		}
	},
	"inputs": [
		{
			"type": "text",
			"key": "max_time",
			"label": "Time",
			"label_visible": false,
			"initial": "01:00:00",
			"max_length": 8
		}
	],
	"can_close_with_escape": true,
	"pause": false,
	"columns": 2,
	"actions": [
		{"label": "Confirm", "action": {"type": "dynamic/run_command", "template": "data modify storage config:settings edit.max_time set value \"$(max_time)\""}},

		{"label": { "text": "Back to ", "extra": [{"text": "edit ", "color": "gold", "italic": true}, {"text": "menu"}]}, "action": {"type": "show_dialog", "dialog": "config:menu/edit"}},
		{"label": { "text": "Back to ", "extra": [{"text": "menu", "color": "gold", "italic": true}]}, "action": {"type": "show_dialog", "dialog": "config:menu"}},
		{"label": { "text": "Back to main menu"}, "action": {"type": "show_dialog", "dialog": "config:config"}}
	]
}
