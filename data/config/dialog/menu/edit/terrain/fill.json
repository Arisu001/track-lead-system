{
	"type": "multi_action",
	"title": {
		"text": "Fill",
		"color": "green"
	},
	"body": {
		"type": "item",
		"item": {
			"id": "powder_snow_bucket"
		}
	},
	"inputs": [
		{
			"type": "text",
			"key": "fill_block",
			"label": {
				"text": "Block",
				"color": "green"
			},
			"initial": "grass_block",
			"max_length": 35
		},
		{
			"type": "single_option",
			"key": "fill_mode",
			"label": {
				"text": "Mode",
				"color": "white"
			},
			"options": [
				{"id": "destroy", "display": {"text": "Destroy", "color": "gray"}, "initial": false},
				{"id":  "hollow", "display": {"text":  "Hollow", "color": "gray"}, "initial": false},
				{"id":    "keep", "display": {"text":    "Keep", "color": "gray"}, "initial": false},
				{"id": "outline", "display": {"text": "Outline", "color": "gray"}, "initial": false},
				{"id": "replace", "display": {"text": "Replace", "color": "gray"}, "initial": false},
				{"id":  "strict", "display": {"text":  "Strict", "color": "gray"}, "initial": false}
			]
		},
		{
			"type": "text",
			"key": "replace_block",
			"label": {
				"text": "Only in \"Replace\" mode",
				"color": "light_purple"
			},
			"initial": "\"minecraft:stone\"",
			"max_length": 35
		},
		{
			"type": "single_option",
			"key": "replace_mode",
			"label": {
				"text": "Mode",
				"color": "white"
			},
			"options": [
				{"id": "destroy", "display": {"text": "Destroy", "color": "gray"}, "initial": false},
				{"id":  "hollow", "display": {"text":  "Hollow", "color": "gray"}, "initial": false},
				{"id":    "keep", "display": {"text":    "Keep", "color": "gray"}, "initial": false},
				{"id":  "strict", "display": {"text":  "Strict", "color": "gray"}, "initial": false}
			]
		}
	],
	"can_close_with_escape": true,
	"pause": false,
	"columns": 2,
	"actions": [
		{"label": "Confirm", "action": {"type": "dynamic/run_command", "template": "function config:events/edit/terrain/fill {fill_block: \"$(fill_block)\", fill_mode: \"$(fill_mode)\", replace_block: \"$(replace_block)\", replace_mode: \"$(replace_mode)\"}"}},

		{"label": { "text": 		  "Back to ", "extra": [{"text": "terrain ", "color": "#5DBB63", "italic":   true}, {"text": "menu"}]}, "action": {"type": "show_dialog", "dialog": "config:menu/edit/terrain"}},
		{"label": { "text": 		  "Back to ", "extra": [{"text":    "edit ", "color":    "gold", "italic":   true}, {"text": "menu"}]}, "action": {"type": "show_dialog", "dialog": 		"config:menu/edit"}},
		{"label": { "text": 		  "Back to ", "extra": [{"text":     "menu", "color":    "gold", "italic": true}]}, 					"action": {"type": "show_dialog", "dialog": 		     "config:menu"}},
		{"label": { "text": "Back to main menu"}, 																				       		"action": {"type": "show_dialog", "dialog":            "config:config"}}
	]
}
