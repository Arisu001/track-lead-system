{
	"type": "multi_action",
	"title": {
		"text": "Setblock",
		"color": "white"
	},
	"body": {
		"type": "item",
		"item": {
			"id": "structure_block"
		}
	},
	"inputs": [
		{
			"type": "boolean",
			"key": "from",
			"label": {
				"text": "From",
				"color": "gray"
			},
			"initial": false,
			"on_true": "from",
			"on_false": "false"
		},
		{
			"type": "text",
			"key": "from_dimension",
			"label": {
				"text": "From = True",
				"color": "aqua"
			},
			"initial": "\"example:minigames/my_dimension\"",
			"max_length": 100
		},
		{
			"type": "boolean",
			"key": "to",
			"label": {
				"text": "To   ",
				"color": "gray"
			},
			"initial": false,
			"on_true": "to",
			"on_false": "false"
		},
		{
			"type": "text",
			"key": "to_dimension",
			"label": {
				"text": "To = True",
				"color": "light_purple"
			},
			"initial": "overworld",
			"max_length": 100
		},
		{
			"type": "single_option",
			"key": "mask_mode",
			"label": {
				"text": "Mode",
				"color": "white"
			},
			"options": [
				{"id": "filtered", "display": {"text": "Filtered", "color": "gray"}, "initial": false},
				{"id":   "masked", "display": {"text":   "Masked", "color": "gray"}, "initial": false},
				{"id":  "replace", "display": {"text":  "Replace", "color": "gray"}, "initial": false},
				{"id":   "strict", "display": {"text":   "Strict", "color": "gray"}, "initial": false}
			]
		},
		{
			"type": "single_option",
			"key": "mask_mode_strict",
			"label": {
				"text": "Only in \"Strict\" mode",
				"color": "white"
			},
			"options": [
				{"id": "filtered", "display": {"text": "Filtered", "color": "gray"}, "initial": false},
				{"id":   "masked", "display": {"text":   "Masked", "color": "gray"}, "initial": false},
				{"id":  "replace", "display": {"text":  "Replace", "color": "gray"}, "initial": false}
			]
		},
		{
			"type": "text",
			"key": "clone_block",
			"label": {
				"text": "Only in \"Filtered\" & \"Strict\" modes",
				"color": "aqua"
			},
			"initial": "\"#logs\"",
			"max_length": 35
		},
		{
			"type": "single_option",
			"key": "clone_mode",
			"label": {
				"text": "Mode",
				"color": "white"
			},
			"options": [
				{"id":  "force", "display": {"text":  "Force", "color": "gray"}, "initial": false},
				{"id":   "move", "display": {"text":   "Move", "color": "gray"}, "initial": false},
				{"id": "normal", "display": {"text": "normal", "color": "gray"}, "initial": false}
			]
		}
	],
	"can_close_with_escape": true,
	"pause": false,
	"columns": 2,
	"actions": [
		{"label": "Confirm", "action": {"type": "dynamic/run_command", "template": "function config:events/edit/terrain/clone {from: \"$(from)\", from_dimension: \"$(from_dimension)\", to: \"$(to)\", to_dimension: \"$(to_dimension)\", mask_mode: \"$(mask_mode)\", mask_mode_strict: \"$(mask_mode_strict)\",  clone_block: \"$(clone_block)\", clone_mode: \"$(clone_mode)\"}"}},

		{"label": { "text": 		  "Back to ", "extra": [{"text": "terrain ", "color": "#5DBB63", "italic":   true}, {"text": "menu"}]}, "action": {"type": "show_dialog", "dialog": "config:menu/edit/terrain"}},
		{"label": { "text": 		  "Back to ", "extra": [{"text":    "edit ", "color":    "gold", "italic":   true}, {"text": "menu"}]}, "action": {"type": "show_dialog", "dialog": 		"config:menu/edit"}},
		{"label": { "text": 		  "Back to ", "extra": [{"text":     "menu", "color":    "gold", "italic": true}]}, 					"action": {"type": "show_dialog", "dialog": 		     "config:menu"}},
		{"label": { "text": "Back to main menu"}, 																				       		"action": {"type": "show_dialog", "dialog":            "config:config"}}
	]
}
