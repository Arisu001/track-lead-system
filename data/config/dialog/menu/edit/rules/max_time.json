{
	"type": "multi_action",
	"title": {
		"text": "Max Time",
		"color": "#EF4444"
	},
	"body": {
		"type": "item",
		"item": {
			"id": "clock"
		}
	},
	"inputs": [
		{"type": "number_range", "key":    "hour",    "label":         "Hour",         "start": 0, "end": 59, "step": 1, "initial":  0},
		{"type": "number_range", "key":  "minute",    "label":       "Minute",         "start": 0, "end": 59, "step": 1, "initial": 30},
		{"type": "number_range", "key": "seconde",    "label": 		"Seconde",         "start": 0, "end": 59, "step": 1, "initial":  0},
		{"type": "number_range", "key":    "tick",    "label": "Milliseconde",         "start": 0, "end": 20, "step": 1, "initial":  0}
	],
	"can_close_with_escape": true,
	"pause": false,
	"columns": 2,
	"actions": [
		{"label": "Confirm", "action": {"type": "dynamic/run_command", "template": "function config:events/edit/rules/set_time {hour: \"$(hour)\", minute: \"$(minute)\", seconde: \"$(seconde)\", tick: \"$(tick)\"}"}},

		{"label": { "text": 		  "Back to ", "extra": [{"text": "rules ", "color": "#FF6D00", "italic":   true}, {"text": "menu"}]}, "action": {"type": "show_dialog", "dialog": "config:menu/edit/rules"}},
		{"label": { "text": 		  "Back to ", "extra": [{"text":  "edit ", "color":    "gold", "italic":   true}, {"text": "menu"}]}, "action": {"type": "show_dialog", "dialog": 		"config:menu/edit"}},
		{"label": { "text": 		  "Back to ", "extra": [{"text":   "menu", "color":    "gold", "italic": true}]}, 					  "action": {"type": "show_dialog", "dialog": 		     "config:menu"}},
		{"label": { "text": "Back to main menu"}, 																				          "action": {"type": "show_dialog", "dialog":     		   "config:config"}}
	]
}
